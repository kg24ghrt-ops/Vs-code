{
  "name": "remote-runner",
  "displayName": "Remote Runner",
  "description": "Remote code execution via GitHub Actions for students.",
  "version": "1.0.0",
  "publisher": "your-name-or-org",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/remote-runner.git"
  },
  "license": "MIT",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "remote-runner.setup", "title": "Remote Runner: Setup Workspace" },
      { "command": "remote-runner.run", "title": "Remote Runner: Run on Remote" }
    ],
    "configuration": {
      "title": "Remote Runner",
      "properties": {
        "remoteRunner.studentName": { "type": "string", "default": "student1", "description": "Student ID" }
      }
    }
  }
}