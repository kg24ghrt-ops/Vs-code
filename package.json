{
  "name": "remote-runner",
  "displayName": "Remote Runner",
  "description": "Remote code execution for Python and Java via GitHub Actions.",
  "version": "1.4.0",
  "publisher": "student-tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/remote-runner"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onCommand:remote-runner.setup",
    "onCommand:remote-runner.run"
  ],
  "contributes": {
    "commands": [
      {
        "command": "remote-runner.setup",
        "title": "Remote Runner: Setup Workspace",
        "category": "Remote Runner"
      },
      {
        "command": "remote-runner.run",
        "title": "Remote Runner: Run on Remote",
        "category": "Remote Runner"
      }
    ],
    "snippets": [
      {
        "language": "python",
        "path": "./templates/py_snippets.json"
      },
      {
        "language": "java",
        "path": "./templates/java_snippets.json"
      }
    ],
    "configuration": {
      "title": "Remote Runner",
      "properties": {
        "remoteRunner.studentName": {
          "type": "string",
          "default": "student1",
          "description": "Unique student identifier for branch naming."
        },
        "remoteRunner.pollInterval": {
          "type": "number",
          "default": 4000,
          "description": "Delay in ms between log checks."
        }
      }
    }
  }
}