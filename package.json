{
  "name": "remote-runner",
  "displayName": "Remote Runner Pro",
  "description": "Enterprise-grade remote code execution via GitHub Actions.",
  "version": "1.8.9",
  "publisher": "student-tools",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Programming Languages",
    "Testing"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onCommand:remote-runner.setup",
    "onCommand:remote-runner.run",
    "onLanguage:python",
    "onLanguage:java"
  ],
  "contributes": {
    "commands": [
      {
        "command": "remote-runner.setup",
        "title": "Remote Runner: Setup Workspace",
        "category": "Remote Runner",
        "icon": "$(settings-gear)"
      },
      {
        "command": "remote-runner.run",
        "title": "Remote Runner: Run on Remote",
        "category": "Remote Runner",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "remote-runner.run",
          "group": "navigation",
          "when": "resourceLangId == python || resourceLangId == java"
        }
      ]
    },
    "snippets": [
      {
        "language": "python",
        "path": "./templates/py_snippets.json"
      },
      {
        "language": "java",
        "path": "./templates/java_snippets.json"
      }
    ],
    "configuration": {
      "title": "Remote Runner Settings",
      "properties": {
        "remoteRunner.studentName": {
          "type": "string",
          "default": "student1",
          "description": "Unique identifier used for branch and log naming."
        },
        "remoteRunner.pollInterval": {
          "type": "number",
          "default": 2000,
          "description": "Frequency (ms) to check for remote log updates. Lower values feel more live."
        },
        "remoteRunner.timeout": {
          "type": "number",
          "default": 180000,
          "description": "Total time (ms) to wait for a job before timing out."
        }
      }
    }
  }
}