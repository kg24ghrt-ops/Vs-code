{
  "name": "remote-runner",
  "displayName": "Remote Runner",
  "description": "Remote code execution for students via GitHub Actions",
  "version": "1.0.1",
  "publisher": "student-tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/remote-runner"
  },
  "engines": { "vscode": "^1.75.0" },
  "main": "./extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "remote-runner.setup", "title": "Remote Runner: Setup Workspace" },
      { "command": "remote-runner.run", "title": "Remote Runner: Run on Remote" }
    ],
    "configuration": {
      "title": "Remote Runner",
      "properties": {
        "remoteRunner.studentName": { "type": "string", "default": "student1" }
      }
    }
  }
}